   228	
   229	def _label_pattern(label: str) -> re.Pattern:
   230	    """Tolerant leaf-field label matcher (section 4.3 + S10 + R4).
   231	
   232	    Tolerates a leading `#`/`-`/`*`/whitespace run, the label wrapped in
   233	    `**bold**`, extra whitespace around the colon, and -- the R4 fix -- a
   234	    closing `**` sitting *after* the colon as in `**Label:** value` (where
   235	    the colon is inside the bold span). Without the `\\**` right after the
   236	    literal colon, that form would leak the closing `**` into the captured
   237	    value, making an empty `**Label:**` field look non-blank.
   238	    """
   239	    return re.compile(
   240	        r"^[#\-*\s]*\**\s*" + re.escape(label) + r"\s*\**\s*:\s*\**\s*(.*)$"
   241	    )
   242	
   243	
   244	def _container_pattern(container: str) -> re.Pattern:
   245	    """Container-line matcher: same tolerances as a leaf label, but the line
   246	    must end right after the colon (nothing but optional bold/space), since
   247	    a container is followed by a sub-list rather than an inline value."""
   248	    return re.compile(
   249	        r"^[#\-*\s]*\**\s*" + re.escape(container) + r"\s*\**\s*:\s*\**\s*$"
   250	    )
   251	
   252	
   253	def _clean_value(raw: str) -> str:
   254	    value = raw.strip()
   255	    value = re.sub(r"^\*+", "", value).strip()
   256	    return value
   257	
   258	
   259	def _find_heading_slice(lines: List[str], heading: str) -> Optional[Tuple[int, int]]:
   260	    """Return the (start, end) line-index range of the content strictly
   261	    under `## heading`, up to the next heading of equal-or-higher level or
   262	    end of file (section 4.3 step 1)."""
   263	    start_idx = None
   264	    start_level = None
   265	    for i, line in enumerate(lines):
   266	        m = _HEADING_RE.match(line)
   267	        if m and m.group(2) == heading:
   268	            start_idx = i
   269	            start_level = len(m.group(1))
   270	            break
   271	    if start_idx is None:
   272	        return None
   273	    end_idx = len(lines)
   274	    for j in range(start_idx + 1, len(lines)):
   275	        m = _HEADING_RE.match(lines[j])
   276	        if m and len(m.group(1)) <= start_level:
   277	            end_idx = j
   278	            break
   279	    return start_idx + 1, end_idx
   280	
   281	
   282	def _find_container_slice(
   283	    lines: List[str], start: int, end: int, container: str, other_containers: List[str]
   284	) -> Optional[Tuple[int, int]]:
   285	    """Return the (start, end) line-index range of the content under the
   286	    named container line, bounded by the next sibling container line (from
   287	    `other_containers`) or the enclosing slice end (section 4.3 step 2)."""
   288	    cont_re = _container_pattern(container)
   289	    c_start = None
   290	    for i in range(start, end):
   291	        if cont_re.match(lines[i]):
   292	            c_start = i
   293	            break
   294	    if c_start is None:
   295	        return None
   296	    other_res = [_container_pattern(c) for c in other_containers if c != container]
   297	    c_end = end
   298	    for j in range(c_start + 1, end):
   299	        if any(r.match(lines[j]) for r in other_res):
   300	            c_end = j
   301	            break
   302	    return c_start + 1, c_end
   303	
   304	
   305	def _containers_by_heading(fields: List[tuple]) -> dict:
   306	    result: dict = {}
   307	    for heading, container, _label in fields:
   308	        if heading and container:
   309	            result.setdefault(heading, [])
   310	            if container not in result[heading]:
   311	                result[heading].append(container)
   312	    return result
   313	
   314	
   315	def locate_field_line(
   316	    text: str, rel: str, heading: Optional[str], container: Optional[str], label: str
   317	) -> Optional[int]:
   318	    """Return the 0-based line index of a leaf field's label line within
   319	    `text` (the contents of manifest file `rel`), honoring the same
   320	    heading/container slicing detection uses. Exposed (not internal-only) so
   321	    `validate.py`'s programmatic fixture construction (design-v2 section
   322	    7.2) can locate the exact line to fill without re-implementing the
   323	    section 4.3 slicing algorithm, keeping fixture generation and detection
   324	    from drifting apart. `rel` disambiguates which file's manifest entry
   325	    owns `(heading, container)` -- heading names happen to be unique across
   326	    the 5 files today, but taking `rel` explicitly avoids relying on that.
   327	    """
   328	    lines = text.splitlines()
   329	    if heading:
   330	        hs = _find_heading_slice(lines, heading)
   331	        if hs is None:
   332	            return None
   333	        start, end = hs
   334	    else:
   335	        start, end = 0, len(lines)
   336	
   337	    if container:
   338	        other_containers = _containers_by_heading(MANIFEST[rel]["fields"]).get(heading, [])
   339	        cs = _find_container_slice(lines, start, end, container, other_containers)
   340	        if cs is None:
   341	            return None
   342	        start, end = cs
   343	
   344	    label_re = _label_pattern(label)
   345	    for i in range(start, end):
   346	        if label_re.match(lines[i]):
   347	            return i
   348	    return None
