   409	def validate_doc_consistency() -> None:
   410	    print("[5/8] Documentation skeleton consistency (source of truth: init_project.py)")
   411	    dirs, files = skeleton_entries()
   412	
   413	    # usage.md documents the initializer output as a bullet list, not a tree.
   414	    doc_paths = [
   415	        (REPO_ROOT / "README.md", True),
   416	        (REPO_ROOT / "docs" / "usage.md", False),
   417	        (REPO_ROOT / "docs" / "harnessloop-framework.md", True),
   418	        (PLUGIN_ROOT / "skills" / "harnessloop-loop" / "SKILL.md", True),
   419	        (PLUGIN_ROOT / "skills" / "harnessloop-init" / "SKILL.md", True),
   420	    ]
   421	
   422	    for doc, tree_only in doc_paths:
   423	        text = doc.read_text(encoding="utf-8")
   424	        rel_doc = doc.relative_to(REPO_ROOT)
   425	        scope = skeleton_blocks(text) if tree_only else text
   426	        if ".harnessloop/" not in scope:
   427	            check(False, f"{rel_doc} contains a .harnessloop skeleton block")
   428	            continue
   429	        missing_dirs = sorted(d for d in {top_level(x) for x in dirs} if d not in scope)
   430	        missing_files = sorted(f for f in files if Path(f).name not in scope)
   431	        check(not missing_dirs, f"{rel_doc} skeleton includes all top-level dirs (missing: {missing_dirs or 'none'})")
   432	        check(not missing_files, f"{rel_doc} skeleton includes all init-created files (missing: {missing_files or 'none'})")
   433	
