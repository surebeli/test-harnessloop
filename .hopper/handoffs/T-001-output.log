   220	_HEADING_RE = re.compile(r"^(#{1,6})\s+(.*?)\s*$")
   221	
   222	# S1 (tightened): requires the literal phrase `(confirmed via setup wizard)`;
   223	# only `No`/`None` is case-insensitive, the parenthetical is verbatim.
   224	_SENTINEL_RE = re.compile(
   225	    r"^_?\s*(?:(?i:no|none))\b[^_\n]*\(confirmed via setup wizard\)\.?_?\s*$"
