   375	def skeleton_entries() -> tuple[set[str], set[str]]:
   376	    """Authoritative skeleton from init_project.py constants."""
   377	    dirs = {rel.removeprefix(".harnessloop/") for rel in init_project.BASE_DIRS}
   378	    files = {
   379	        rel.removeprefix(".harnessloop/")
   380	        for mapping in (init_project.BASE_FILES, init_project.LOCAL_FILES, init_project.INTAKE_FILES)
   381	        for rel in mapping
   382	    }
   383	    return dirs, files
