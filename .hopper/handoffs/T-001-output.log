   766	def validate_claude_strict() -> None:
   767	    print("[8/8] Claude strict plugin validation")
   768	    if os.environ.get("HARNESSLOOP_SKIP_CLAUDE") == "1":
   769	        print("  skipped: HARNESSLOOP_SKIP_CLAUDE=1")
   770	        return
   771	
   772	    claude = (
   773	        shutil.which("claude")
   774	        or shutil.which("claude.cmd")
   775	        or shutil.which("claude.exe")
   776	        or os.environ.get("CLAUDE_CLI")
   777	    )
   778	    if not claude:
   779	        check(False, "claude CLI found on PATH (or set CLAUDE_CLI, or HARNESSLOOP_SKIP_CLAUDE=1)")
   780	        return
   781	
   782	    for target in (REPO_ROOT, PLUGIN_ROOT):
   783	        result = subprocess.run(
   784	            [claude, "plugin", "validate", "--strict", str(target)],
   785	            capture_output=True,
   786	            text=True,
   787	            encoding="utf-8",
   788	            errors="replace",
   789	            shell=False,
   790	        )
   791	        output = (result.stdout or "") + (result.stderr or "")
   792	        passed = result.returncode == 0 and "Validation failed" not in output
   793	        check(passed, f"claude plugin validate --strict {target.name or target}")
   794	        if not passed:
   795	            print(output)
