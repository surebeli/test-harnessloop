   239	//
   240	// v2 修订（消解 F-11：v1 无 session 参数、纯内核级静态声明，被判定违反 INV-4）：
   241	// capabilities() 本身仍然是"某一时刻的快照"查询语义，不是订阅式接口——
   242	// 真正的"能力可能中途变化，如何感知"这个问题，v2 不是靠让 capabilities() 变成流式接口解决，
   243	// 而是靠 §3 新增的 capability_changed 事件 + §4 的双来源变更模型解决。
   244	// 两者分工：capabilities() 负责"此刻是什么"，capability_changed 事件负责"变了，请重新查/据此更新缓存"。
   245	```
   246	
   247	## 3. KernelEvent Schema
   248	
   249	`subscribe()` 产出的事件是以下 **9 类**的判别联合（discriminated union）：**8 类内核事件**（来自 openclaw/hermes 原生事件流的翻译）+ **1 类我方控制面事件**（`capability_changed`，见下方与 §4 的说明，来源是我方 Server，不是内核）。
   250	
   251	```ts
   252	type KernelEvent =
   253	  | MessageDeltaEvent
   254	  | ThinkingEvent
   255	  | ToolCallEvent
   256	  | ToolResultEvent
   257	  | ApprovalRequestEvent
   258	  | ErrorEvent
   259	  | TurnCompleteEvent
   260	  | SessionEndEvent
   261	  | CapabilityChangedEvent;   // v2 新增，见下方说明
   262	
   263	interface KernelEventBase {
   264	  protocolVersion: string;
   265	  // v3 新增（内部 M6，消解 S-09「契约无版本治理字段」的部分）：本事件所遵循的 KernelPort 契约
   266	  // 版本号（如 "v3"）。v2 本身的字段级变更（如 ApprovalRequestEvent 新增必填字段）就是一次无
   267	  // 过渡路径的破坏性变更的真实案例；本字段只是治理层面的最小起步——让消费方至少能区分"我收到的
   268	  // 事件产自哪个契约版本"，不代表已经有完整的版本协商/兼容策略（那仍是更大的设计问题，本 spec
   269	  // 不在此展开，见 §10 S-09 行与 §11）。`capabilities()` 返回的 CapabilityDescriptor 同样携带
   270	  // 该字段（§4.1），两处配合可供调用方在方法调用层面查询"当前 KernelPort 契约版本"。
   271	  seq: number;
   272	  // v2 收紧语义（消解 F-12）：仅保证同一 runId 内的 lifecycle/assistant/tool 事件排序，
   273	  // 不承诺跨 run、跨连接、跨 session 的全局单调性或唯一性——v1 "session 内单调递增、唯一"
   274	  // 缺乏事实支持（T-005 官方原文只确认 outer 连接级 seq 每连接单调、新连接重置，
   275	  // 与 agent 事件 payload 内按 run 分配的 seq 是两层不同的东西），已删除该断言。
   276	  // session 级事件（如 session_end）不参与按 runId 排序，其 seq 仅具备"同一订阅内先后到达"
   277	  // 的弱含义，客户端不应据其做跨类型/跨 run 比较。
   278	  sessionId: string;
   279	  runId?: string;       // 归属的 send() 产生的 run；session 级事件（session_end、capability_changed）可省略
   280	  ts: string;
   281	  // ISO 8601。v2 明确其来源随内核而异：openclaw 提供事件自带时间戳；hermes CLI/ACP 流
   282	  // 未确认原生逐事件时间戳，适配器可能需要用接收时刻合成——此时 ts 反映的是"适配器观测到
   283	  // 该事件的时间"而非"内核产生该事件的时间"，两者在 hermes 侧可能无法区分，如实标注不假装精确。
   284	}
   285	
   286	interface MessageDeltaEvent extends KernelEventBase {
   287	  type: 'message.delta';
   288	  role: 'assistant';
   289	  delta: string;
   290	  index: number;
   291	}
   292	
   293	interface ThinkingEvent extends KernelEventBase {
   294	  type: 'thinking';
   295	  delta: string;
   296	  visibility: 'summary' | 'raw';
   297	}
   298	
   299	interface ToolCallEvent extends KernelEventBase {
   300	  type: 'tool_call';
   301	  toolCallId: string;
   302	  name: string;
   303	  input: unknown;
   304	  status: 'started';
   305	}
   306	
   307	interface ToolResultEvent extends KernelEventBase {
   308	  type: 'tool_result';
   309	  toolCallId: string;
   310	  output: unknown;
   311	  isError: boolean;
   312	  durationMs?: number;
   313	}
   314	
   315	interface ApprovalRequestEvent extends KernelEventBase {
   316	  type: 'approval_request';
   317	  reqId: string;          // respondApproval() 的关联主键（= 内核 approval id，非 toolCallId，见 T-005 A1）
   318	  toolCallId: string;      // v2 新增必填（消解 F-14）：关联到对应 ToolCallEvent.toolCallId，
   319	                            // 供 UI/审计把 approval_request ↔ tool_call ↔ tool_result 串起来；
   320	                            // 不是 respondApproval 的关联键，只是审计/展示用的一等关联字段。
   321	  runId: string;           // v2 收紧为必填（v1 是可选）——§9 约束"一 session 一次一个 active run"后，
   322	                            // 审批必然归属某个明确的 run，不再需要允许省略。
   323	  kind: 'exec' | 'tool' | 'mcp' | 'sandbox' | 'file_write';
   324	  payload: unknown;
   325	  proposedDecision?: 'allow_once' | 'allow_always' | 'deny';
   326	  timeoutMs: number;       // v2 收紧为必填（v1 是可选）——两内核均已确认存在超时→deny 语义
   327	                            // （openclaw 30 分钟默认过期；hermes bridge 错误/超时→deny，
   328	                            // 但 hermes 的具体时长如约 60s 是"实现细节风险"而非官方承诺，
   329	                            // 适配器据此字段填的是"本内核已知的最佳估计值"，不是跨内核统一的保证值，
   330	                            // 见 §6.2）。
   331	  timeoutAuthority: 'documented' | 'best_effort';
   332	  // v3 新增（内部 M1）：钉死 timeoutMs 这条时钟的权威归属，避免 UI 把两内核的超时可靠性混为一谈。
   333	  // openclaw 'documented'——30 分钟默认过期有官方文档担保（T-005 §1a）。
   334	  // hermes 'best_effort'——约 60s 来自 GitHub issue 旁证的实现细节风险，非官方承诺（T-005 §2a）。
   335	  // UI 不得在 'best_effort' 上做精确倒计时，只能做方向性提示（见 §11 开放问题 #3）。
   336	}
   337	
   338	interface ErrorEvent extends KernelEventBase {
   339	  type: 'error';
   340	  code: KernelErrorCode;        // 封闭枚举，见 §9
   341	  message: string;
   342	  nativeCode?: string;          // 内核原生错误码/类型，仅供调试参考，非契约稳定字段，
   343	                                  // UI/P3 不得对其分支判断（呼应 INV-1）
   344	  recoverable: 'run' | 'session' | 'none';
   345	  // v2 修订（明确 run 级 vs session 级，v1 是笼统的 boolean）：
   346	  // 'run'：仅当前 run 受影响，session 仍可继续 send()；
   347	  // 'session'：整个 session 已不可用，调用方应视同已收到 session_end 并停止再 send()
   348	  //   （适配器通常会紧随发出 SessionEndEvent）；
   349	  // 'none'：不可恢复，通常伴随 kernel_crashed 或 transport 层面不可逆断开。
   350	}
   351	
   352	interface TurnCompleteEvent extends KernelEventBase {
   353	  type: 'turn_complete';
   354	  runId: string;
   355	  stopReason: 'completed' | 'cancelled' | 'error' | 'max_turns';
   356	  degraded?: { kind: 'steer_via_cancel_resend' };
   357	  // v3 修订（§6.1a，消解 nextRunId 时序悖论）：当 stopReason==='cancelled' 且这次 cancel 是
   358	  // 适配器为 hermes 实现"无原生 steer 时的 cancel+resend"降级路径的第一步时，标注本字段。
   359	  // v2 曾要求本字段携带 nextRunId，但该值在本事件产出时刻（cancel 已完成、resend 尚未发起）
   360	  // 根本不存在——这是 [[d1-v2-review-dual-track]] 判定的 BLOCKER 时序悖论（grok E1），v3 移除
   361	  // nextRunId，本字段只标注"这是一次 steer 降级序列"，不承诺此刻能提供下一个 run 的 id；
   362	  // 新 run 的 id 关联方式见 §6.1a（interrupt() 返回值 + §9.3 并发保护）。UI/P3 据此如实呈现
   363	  // "这次转向丢弃了当前 run 未产出内容、是重新开始"，不得假装体验无损。
   364	  // 本字段仅出现于 hermes；openclaw 走原生 sessions.steer，不产生 degraded。
   365	  forceResolvedApprovals?: string[];
   366	  // v2 新增（§6.2 审批状态机）：因本次 stop/cancel 被强制终态化（force-deny）的 approval reqId 列表，
   367	  // 空/省略 = 无。这是"interrupt/stop 时强制 reject 挂起审批"这一动作对调用方可感知的信号。
   368	  usage?: { inputTokens?: number; outputTokens?: number };  // 尽力字段，非计费权威来源，见 §7
   369	}
   370	
   371	interface SessionEndEvent extends KernelEventBase {
   372	  type: 'session_end';
   373	  reason: 'stopped' | 'kernel_exited' | 'transport_closed' | 'error';
   374	}
   375	
   376	interface CapabilityChangedEvent extends KernelEventBase {
   377	  type: 'capability_changed';
   378	  source: 'server_override' | 'kernel_error_inferred';
   379	  // 'server_override'：我方 Server 侧能力开关/feature flag/租户策略主动决策产生的推送
   380	  //   （§4 能力变更模型来源①）。
   381	  // 'kernel_error_inferred'：适配器捕获到内核 RPC 报错（openclaw 的 FORBIDDEN/MISSING_SCOPE/
   382	  //   AUTH_SCOPE_MISMATCH 等）后，推断能力已收紧而合成的信号（§4 能力变更模型来源②）。
   383	  // 两种来源都不是内核原生事件——T-005 §1a/§2a 已双重确认 openclaw 与 hermes 都没有
   384	  // capabilities_changed 类事件，本事件是窄腰层（我方控制面）合成注入的，
   385	  // 之所以放进同一个 KernelEvent 判别联合、走同一条 subscribe() 流，只是为了给 UI/P3
   386	  // 提供单一事件源的消费体验，绝不代表这是"内核通知我们的"，这一点必须在实现与文档里反复强调，
   387	  // 避免重蹈 v1 假设内核会通知能力变化的错误（[[d1-review-dual-track]] 交集 #4/F-11）。
   388	  capabilities: CapabilityDescriptor;   // 变更后的完整快照（非增量 diff，避免版本对不齐的歧义）
   389	  reason?: string;                       // 人类可读的变更原因摘要
   390	}
   391	```
   392	
   393	## 4. CapabilityDescriptor + 能力变更模型
   394	
   395	### 4.1 CapabilityDescriptor（连接时快照）
   396	
   397	```ts
   398	interface CapabilityDescriptor {
   399	  protocolVersion: string;   // v3 新增（内部 M6），同 KernelEventBase.protocolVersion（§3）；
   400	                              // 供调用方在方法调用层面（无需等事件）查询当前 KernelPort 契约版本
   401	  kernel: KernelKind;
   402	  kernelVersion?: string;    // 尽力而为；OpenClaw npm latest 版本号动态未锁定
   403	  snapshotAt: string;        // v2 新增：本快照生成时间（ISO 8601），呼应"capabilities() 是连接时快照"定位
   404	
   405	  tools: {
   406	    discoverable: boolean;   // 能否枚举工具目录（如 OpenClaw tools.catalog）
   407	    names?: string[];
   408	  };
   409	
   410	  approvalGranularity: 'per-tool' | 'per-command' | 'batch';
   411	  approvalKinds: Array<'exec' | 'tool' | 'mcp' | 'sandbox' | 'file_write'>;
   412	
   413	  interruptModes: Array<'steer' | 'cancel'>;   // 至少含 'cancel'；v3 起 openclaw/hermes 均含 'steer'
   414	                                                 // （质量差异见下方 steerNative，§6.1 详述）
   415	  steerNative?: boolean;
   416	  // v3 新增：仅当 interruptModes 含 'steer' 时有意义。
   417	  // true = 原生保留产出（openclaw sessions.steer；其"是否真正保留已产出内容"的精确语义未完全
   418	  //   确认，见 §6.1「诚实标注」）。
   419	  // false/省略 = 经适配器内部 cancel+resend 模拟（hermes），必然丢弃当前 run 未产出内容，且必然
   420	  //   伴随 TurnCompleteEvent.degraded 信号。
   421	
   422	  streamingGranularity: 'token-delta' | 'chunk' | 'message-only';
   423	
   424	  sessionResume: boolean;
   425	  thinkingVisibility: 'none' | 'summary' | 'raw';
   426	  sandboxLevels?: Array<'read-only' | 'workspace-write' | 'full-access'>;
   427	
   428	  usageReporting: 'none' | 'best-effort' | 'authoritative';
   429	  // 计费权威始终在 newapi（§7），openclaw/hermes 都不应声明 'authoritative'
   430	}
   431	```
   432	
   433	### 4.2 能力变更模型
   434	
   435	**事实约束（先说清楚内核不提供什么）**：T-005 §1a/§2a 双重确认，openclaw 与 hermes **都没有** `capabilities_changed` 类事件；能力变化只能靠后续 RPC 报错（openclaw 的 `FORBIDDEN`/`MISSING_SCOPE`/`AUTH_SCOPE_MISMATCH`）或 reconnect/pairing 流程感知，不存在跨内核统一的"能力变更推送"。v1 把 `capabilities()` 设计成无 session 参数的内核级静态声明，本质上是在假装这个不存在的信号能被拿到——这是 v1 违反 INV-4 的直接原因。
   436	
   437	v2 承认"能力协商的中途变化，本质上有两种完全不同的来源"，不再混为一谈：
   438	
   439	1. **我方 Server 主动决策（`server_override`）**：能力开关本质上是我方 Server 的产品决策，不是内核的运行时事实——例如"这个 session 当前要不要展示 steer 按钮"、"哪些 approvalKinds 要展示"，由我方 Server 配置/feature flag/租户级策略决定。Server 通过**我方自己的推送通道**（不是内核事件）下发这个决策，适配器把它包装成 `CapabilityChangedEvent(source:'server_override')` 注入 `subscribe()` 流。
   440	2. **内核侧真实能力收紧（`kernel_error_inferred`）**：只能靠 RPC 报错或 reconnect 发现——适配器捕获到 `FORBIDDEN`/`MISSING_SCOPE`/`AUTH_SCOPE_MISMATCH` 后，主动降级本地缓存的 capabilities 快照，并合成一次 `CapabilityChangedEvent(source:'kernel_error_inferred')`，不再等待一个不存在的内核事件。
   441	
   442	**客户端工具门控（调用前拦截）**：UI/P3 在调用 `send()`/`interrupt()`/`respondApproval()` 之类操作前，应结合最近一次 `capabilities()` 快照与最近一次 `capability_changed` 事件的叠加结果，决定是否展示对应操作入口。但 KernelPort 适配器层本身也做兜底校验（例如 `interrupt(mode:'steer')` 在能力不支持时必须 reject，见 §2.4）——这是"防止 UI 没做好门控时，底层仍不会执行不该执行的操作"的第二道防线，不完全依赖 UI 自觉查 `capabilities()`。
   443	
   444	**INV-4 改写口径**：能力变更感知路径分两种来源——内核 RPC 报错（被动发现）+ 我方 Server override（主动决策），两者都不是内核原生的 `capabilities_changed` 事件；这是本 spec 对 INV-4 的最终落地方式。
   445	
   446	## 5. Transport 映射：GatewayTransport 两条线路（openclaw / hermes）
   447	
   448	v2 只有**一类** Transport（GatewayTransport），因为 v1 的 InProcessTransport（覆盖 Codex SDK/Claude Agent SDK）随 Library 型内核延后而在本 spec 里不存在。openclaw 与 hermes 都是长驻进程 + 显式 session id + 服务端 push 的 Daemon/Gateway 型，但 hermes 内部本身是 **ACP + CLI 混合线路**（不是单一线路），需要如实标注哪个方法走哪条线路，不能笼统地说"hermes 支持全部 7 方法"。
   449	
   450	| KernelPort 方法 | openclaw 底层机制 | hermes 底层机制 |
   451	|---|---|---|
   452	| createSession | WS `sessions.create`（先完成 `connect`→`connect.challenge`→签名→`hello-ok` 握手） | CLI 新建会话（SQLite+FTS5 落盘）或 ACP `new_session`（`hermes acp`，stdio JSON-RPC） |
   453	| send | `chat.send`/`sessions.send` | CLI prompt 输入，或 ACP `prompt` 请求 |
   454	| subscribe | WS 服务端 push `{type:"event", event, payload, seq?}`；`sessions.subscribe(includeApprovals?)` | CLI 标准输出流；ACP `session/update` notification |
   455	| interrupt | mode:'cancel'→`sessions.abort`/`chat.abort`（可携 `runId`，精确寻址，T-005 A5 确认）；mode:'steer'→**原生 `sessions.steer`**（打断并转向，kernel-ecosystem-facts 第 42 行+T-003 确认存在；v3 更正 v2 曾静默否定该事实的回退，见 §6.1；其精确参数/返回字段/"是否真正保留已产出内容"未经 T-005 逐条核查，标注待验证） | ACP `cancel(session_id)`（session 级，无 steer 原生对应，T-005 §2a 确认）；mode:'steer' 时适配器走内部 cancel+resend 降级路径（§6.1/§6.1a），非原生 |
   456	| **stop** | `sessions.abort`/`chat.abort`（先中止活跃/排队 run）→ 确认 `turn_complete` 或超时 → `sessions.delete`（维护/归档）。**两步非原子**，中间可能停留在"已 abort 未 delete"状态。 | **走 CLI 非 ACP**：ACP `cancel(session_id)` 只中断当前 prompt，**不销毁持久会话**（T-005 §2a 确认 ACP 侧无 delete/destroy/stop 动词）；持久删除必须走 CLI 面 `hermes sessions delete`，与 ACP session 生命周期是**两条不同的路径**，适配器需要维护两者之间的映射。这是本 spec 对 v1 F-02（"Hermes stop 未确认当已确认"）的直接更正。 |
   457	| respondApproval | `approval.resolve`/`exec.approval.resolve`（`plugin.approval.*` 同族）；以 approval id 为主键 | **仅 ACP 线路**：ACP permission response（`allow_once`/`allow_always`/`allow_session`/reject）经适配器归一为 `ApprovalDecision`（reject→deny）。CLI TTY 交互式审批**确认无公开可编程协议**（T-005 §2a），生产可编程审批桥统一走 ACP，不假设能程序化桥接经典 CLI TTY prompt。 |
   458	| capabilities | connect 握手 `hello-ok.features.methods/events` + scopes | ACP `initialize` 能力协商（较粗粒度，需适配器补静态 manifest） |
   459	
   460	**已知缺口（引自 kernel-ecosystem-facts）**：openclaw——`features.methods` 未列出的内部方法完整 schema、Plugin SDK 对外发布包稳定 npm 契约细节、生产环境稳定版本号，均**未能确认**；**（v3 新增）`sessions.steer` 的精确调用参数（是否接受 runId）、返回字段形状、以及是否真正"保留已产出内容并注入新指令"（区别于纯 interrupt+followup）均未能确认**——T-005 conformance spike 未专门核查这条，是 [[d1-v2-review-dual-track]] 复核后唯一残留的开放事实缺口（见 §11 第 7 条、§12「同时新增暴露的事实缺口」）。hermes——Hermes api_server 对外 HTTP 会话 API 完整契约、精确的工具审批策略配置 schema，**未能确认**；ACP 是否暴露标准 `session/close` 或内部 `remove` 的对外 RPC 名（持久删除是否仅 CLI 一条路径）**未能确认**（本 spec 按"仅 CLI 一条路径"设计，若未来确认存在 ACP 侧删除动词，可放宽此约束）。openclaw/hermes 运行时协议互通**已确认不存在**，只有 `hermes claw migrate` 迁移工具，不代表两者可共用同一 GatewayTransport 连接实例。
   461	
   462	## 6. 两个硬不对齐点收口
   463	
   464	### 6.1 INV-5/steer 收敛（v3 修订：更正 openclaw 原生 steer 事实回退）
   465	
   466	**openclaw**：[[kernel-ecosystem-facts]] 第 42 行（+ T-003 原始产物第 133 行 + grok T-006 交叉官方 `docs.openclaw.ai/gateway/protocol` 复核）确认 openclaw **原生支持 `sessions.steer`**（打断并转向）；`chat.send` 还支持 `queueMode:'steer'|...`。v2 曾在没有新增否定性 conformance 证据的情况下静默抹除这条已确认事实，用内部 cancel+resend 整条替代覆盖 openclaw——这是 [[d1-v2-review-dual-track]] 判定的事实回退 BLOCKER。v3 更正：
   467	
   468	`interrupt(session, {mode:'steer', input})` 在 openclaw 上**直接映射到 `sessions.steer`**，是一次原生 RPC 调用，不经过 cancel+resend，不产生 `turn_complete.degraded`。
   469	
   470	**诚实标注（未能确认项，v3 新增）**：`sessions.steer` 的精确调用参数是否接受显式 `runId`（T-005 A5 只核查了 `sessions.abort`/`chat.abort` 支持 `runId`，未见对 `steer` 的专门核查）、其返回值字段形状、以及最关键的语义问题——"steer 是否真正保留当前 run 已产出的部分内容并在此基础上注入新指令，还是本质上是 interrupt+followup 的另一种包装"——均**未能确认**，是 [[d1-v2-review-dual-track]] 复核后唯一残留的开放事实缺口（见 §11 第 7 条、§12「同时新增暴露的事实缺口」）。v3 据此采取保守实现约束：`opts.runId` 省略时对该 session 当前 activeRunIds 寻址（与 `abort` 一致的省略语义）；提供 `runId` 时适配器本地做寻址一致性校验，实际 RPC 调用体是否携带该参数由实现按 openclaw 客户端 SDK/协议实际支持情况决定，本 spec 不臆造字段名。`affectedRunId` 返回值：若 `sessions.steer` RPC 响应本身未提供可用标识，适配器可退化为"调用前记录的当前 activeRunId"，须在实现文档标注这不是 steer RPC 的原生返回字段。

