   631	def validate_round_cost_smoke() -> None:
   632	    print("[7/8] Round cost settlement smoke test (round_cost.py)")
   633	    cost_script = LOOP_SCRIPTS / "round_cost.py"
   634	    smoke_root = REPO_ROOT / ".tmp" / f"cost-smoke-{uuid.uuid4().hex}"
   635	    project = smoke_root / "project"
   636	    transcripts = smoke_root / "transcripts"
   637	    try:
   638	        project.mkdir(parents=True)
   639	        transcripts.mkdir(parents=True)
   640	        turn = {
   641	            "type": "assistant",
   642	            "message": {
   643	                "usage": {
   644	                    "input_tokens": 100,
   645	                    "cache_creation_input_tokens": 50,
   646	                    "cache_read_input_tokens": 1000,
   647	                    "output_tokens": 200,
   648	                },
   649	                "content": [{"type": "text", "text": "updating .harnessloop/state/current.md"}],
   650	            },
   651	        }
   652	        business_turn = json.loads(json.dumps(turn))
   653	        business_turn["message"]["content"] = [{"type": "text", "text": "business work"}]
   654	
   655	        # Same-id multi-line usage: Claude Code writes one JSONL line per
   656	        # content block of a single assistant message, and every line for
   657	        # that message.id repeats the message's usage. round_cost.py must
   658	        # dedupe by message.id instead of summing every line, or these two
   659	        # lines for msg_dup001 (still "open" - no closing message after them
   660	        # yet, mirroring round_cost.py normally being invoked from inside
   661	        # the very message it is reporting on) would be billed twice each
   662	        # settlement they're re-scanned in. These assertions fail against
   663	        # the pre-fix per-line-summing logic.
   664	        dup_block_1 = {
   665	            "type": "assistant",
   666	            "message": {
   667	                "id": "msg_dup001",
   668	                "usage": {
   669	                    "input_tokens": 300,
   670	                    "cache_creation_input_tokens": 20,
   671	                    "cache_read_input_tokens": 400,
   672	                    "output_tokens": 50,
   673	                },
   674	                "content": [{"type": "thinking", "thinking": "planning the change"}],
   675	            },
   676	        }
   677	        dup_block_2 = json.loads(json.dumps(dup_block_1))
   678	        dup_block_2["message"]["usage"]["output_tokens"] = 120
   679	        dup_block_2["message"]["content"] = [{"type": "tool_use", "name": "Bash", "input": {}}]
   680	
   681	        (transcripts / "session.jsonl").write_text(
   682	            json.dumps(turn) + "\n"
   683	            + "garbage-line\n"
   684	            + json.dumps(business_turn) + "\n"
   685	            + json.dumps(dup_block_1) + "\n"
   686	            + json.dumps(dup_block_2) + "\n",
   687	            encoding="utf-8",
   688	        )
   689	
   690	        result = run_python(cost_script, "--project", str(project), "--transcript-dir", str(transcripts))
   691	        check(result.returncode == 0, "round_cost.py exits 0 on synthetic transcript")
   692	        check("## Cost" in result.stdout, "round_cost.py emits a ## Cost section")
   693	        check("2 assistant turn(s)" in result.stdout, "round_cost.py counts assistant turns")
   694	        check("1/2 turns" in result.stdout, "round_cost.py attributes protocol turns heuristically")
   695	        check(
   696	            "Output tokens: 400" in result.stdout,
   697	            "round_cost.py defers the still-open msg_dup001 message instead of billing its partial lines",
   698	        )
   699	
   700	        marker_path = project / ".harnessloop" / "local" / "cost-marker.json"
   701	        check(marker_path.exists(), "round_cost.py writes the settlement marker")
   702	        marker = json.loads(marker_path.read_text(encoding="utf-8"))
   703	        pending = marker.get("files", {}).get("session.jsonl", {})
   704	        check(
   705	            pending.get("offset") == 5
   706	            and pending.get("pending_id") == "msg_dup001"
   707	            and pending.get("pending_usage") == {"input": 300, "cache_write": 20, "cache_read": 400, "output": 120},
   708	            "marker carries the still-open message.id and its max-merged usage across the settlement window",
   709	        )
   710	
   711	        # Continue the session: msg_dup001's 3rd (final) content-block line
   712	        # arrives, then a genuinely new message (msg_next002) closes it out.
   713	        # This is the cross-settlement-window case: msg_dup001's lines are
   714	        # split across two round_cost.py runs by the marker offset above,
   715	        # and must still be billed exactly once (using its max usage, not
   716	        # the sum of all 3 lines: 50 + 120 + 150 = 320 would be wrong).
   717	        dup_block_3 = json.loads(json.dumps(dup_block_1))
   718	        dup_block_3["message"]["usage"]["output_tokens"] = 150
   719	        dup_block_3["message"]["content"] = [
   720	            {"type": "text", "text": "done, see .harnessloop/round-summary.md"}
   721	        ]
   722	        next_turn = {
   723	            "type": "assistant",
   724	            "message": {
   725	                "id": "msg_next002",
   726	                "usage": {
   727	                    "input_tokens": 77,
   728	                    "cache_creation_input_tokens": 5,
   729	                    "cache_read_input_tokens": 10,
   730	                    "output_tokens": 33,
   731	                },
   732	                "content": [{"type": "text", "text": "next turn, business as usual"}],
   733	            },
   734	        }
   735	        with (transcripts / "session.jsonl").open("a", encoding="utf-8") as fh:
   736	            fh.write(json.dumps(dup_block_3) + "\n")
   737	            fh.write(json.dumps(next_turn) + "\n")
   738	
   739	        result = run_python(cost_script, "--project", str(project), "--transcript-dir", str(transcripts))
   740	        check(result.returncode == 0, "round_cost.py exits 0 on the continuation window")
   741	        check(
   742	            "1 assistant turn(s)" in result.stdout,
   743	            "round_cost.py bills msg_dup001 exactly once, on the run that observes its closing message",
   744	        )
   745	        check(
   746	            "Input tokens: 300" in result.stdout and "Output tokens: 150" in result.stdout,
   747	            "deduped total matches msg_dup001's max usage across its 3 lines, not their sum (50+120+150=320)",
   748	        )
   749	        check(
   750	            "1/1 turns" in result.stdout and "100% of output" in result.stdout,
   751	            "protocol attribution (mentioned only in msg_dup001's 3rd line) still applies to the whole deduped message",
   752	        )
   753	
   754	        result = run_python(cost_script, "--project", str(project), "--transcript-dir", str(transcripts))
   755	        check(
   756	            result.returncode == 0 and "0 assistant turn(s)" in result.stdout,
   757	            "third settlement reports an empty incremental window (msg_next002 still open, deferred)",
   758	        )
   759	
   760	        result = run_python(cost_script, "--project", str(project), "--transcript-dir", str(smoke_root / "missing"))
   761	        check(result.returncode == 2, "missing transcript dir exits 2")
   762	    finally:
   763	        shutil.rmtree(smoke_root, ignore_errors=True)
