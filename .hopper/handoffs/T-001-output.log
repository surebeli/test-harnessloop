   386	def skeleton_blocks(text: str) -> str:
   387	    """Concatenate fenced code blocks that draw the .harnessloop skeleton.
   388	
   389	    Matching only inside skeleton blocks (not whole-document text) prevents a
   390	    file dropped from the skeleton from being masked by a prose mention.
   391	    """
   392	    blocks: list[str] = []
   393	    fence: list[str] | None = None
   394	    for line in text.splitlines():
   395	        if line.strip().startswith("```"):
   396	            if fence is not None:
   397	                joined = "\n".join(fence)
   398	                if ".harnessloop/" in joined:
   399	                    blocks.append(joined)
   400	                fence = None
   401	            else:
   402	                fence = []
   403	            continue
   404	        if fence is not None:
   405	            fence.append(line)
   406	    return "\n".join(blocks)
   407	
