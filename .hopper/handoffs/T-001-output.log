   439	def validate_protocol_gates() -> None:
   440	    print("[6/8] Mechanical protocol gates (verify_protocol.py)")
   441	    mock_project = REPO_ROOT / "examples" / "mock-project"
   442	    violations = verify_protocol.verify_project(mock_project)
   443	    check(not violations, f"examples/mock-project passes verify ({len(violations)} violation(s))")
   444	    for violation in violations:
   445	        print(f"    {violation['kind']}: {violation['detail']}")
   446	
   447	    # Negative fixtures: verify must FAIL when rules are broken.
   448	    fixture_root = REPO_ROOT / ".tmp" / f"verify-fixture-{uuid.uuid4().hex}"
   449	    round_dir = fixture_root / ".harnessloop" / "goals" / "20260101-001-fixture" / "rounds" / "0001"
   450	    try:
   451	        (round_dir / "evidence" / "runtime").mkdir(parents=True)
   452	        (round_dir / "reviews").mkdir(parents=True)
   453	        (round_dir / "scope-lock.md").write_text(
   454	            "# Scope Lock\n\n## Allowed Changes\n\n- Write evidence under `rounds/0001/evidence/`.\n",
   455	            encoding="utf-8",
   456	        )
   457	        (round_dir / "evidence" / "runtime" / "ok.md").write_text("in scope\n", encoding="utf-8")
   458	        (round_dir / "reviews" / "review.md").write_text(
   459	            "cites `.harnessloop/goals/20260101-001-fixture/rounds/0001/evidence/runtime/missing.md`\n"
   460	            "and source file `src/app/missing_module.py`\n",
   461	            encoding="utf-8",
   462	        )
   463	        violations = verify_protocol.verify_project(fixture_root)
   464	        kinds = {v["kind"] for v in violations}
   465	        check("dangling-citation" in kinds, "verify catches dangling citations (negative fixture)")
   466	        check("scope-lock-violation" in kinds, "verify catches out-of-scope writes (negative fixture)")
   467	        dangling = [v for v in violations if v["kind"] == "dangling-citation"]
   468	        check(
   469	            any("src/app/missing_module.py" in v["detail"] for v in dangling),
   470	            "verify checks source-file citations outside protocol prefixes",
   471	        )
   472	
   473	        # Table-format scope-lock (scope-lock-template.md style) must parse.
   474	        (round_dir / "scope-lock.md").write_text(
   475	            "# Scope Lock\n\n## Allowed Changes\n\n"
   476	            "| Path/data/tool | Allowed action | Limit |\n"
   477	            "| --- | --- | --- |\n"
   478	            "| rounds/0001/evidence/ | write | evidence only |\n"
   479	            "| rounds/0001/reviews/ | write | reviews only |\n",
   480	            encoding="utf-8",
   481	        )
   482	        (round_dir / "reviews" / "review.md").write_text("table-format scope lock round\n", encoding="utf-8")
   483	        violations = verify_protocol.verify_project(fixture_root)
   484	        kinds = {v["kind"] for v in violations}
   485	        check(
   486	            "unparseable-allowed-changes" not in kinds and "scope-lock-violation" not in kinds,
   487	            "verify accepts template-style table scope-locks",
   488	        )
   489	    finally:
   490	        shutil.rmtree(fixture_root, ignore_errors=True)
   491	
   492	    # Rule B pathish false-positive fixtures (evolution issue TH-0006): a
   493	    # real project run turned up six false-positive dangling-citation hits
   494	    # from regex/glob spans, a submodule-relative path, and bare-domain
   495	    # URLs. Cover each exemption plus the explicit verify:ignore escape
   496	    # hatch, and confirm a genuinely dangling citation is still caught
   497	    # (must not trade false positives for false negatives).
   498	    exempt_root = REPO_ROOT / ".tmp" / f"verify-fixture-exempt-{uuid.uuid4().hex}"
   499	    round_dir2 = exempt_root / ".harnessloop" / "goals" / "20260102-001-fixture" / "rounds" / "0001"
   500	    try:
   501	        (round_dir2 / "evidence").mkdir(parents=True)
   502	        (round_dir2 / "reviews").mkdir(parents=True)
   503	        (round_dir2 / "scope-lock.md").write_text(
   504	            "# Scope Lock\n\n## Allowed Changes\n\n"
   505	            "- Write evidence under `rounds/0001/evidence/`.\n"
   506	            "- Write reviews under `rounds/0001/reviews/`.\n",
   507	            encoding="utf-8",
   508	        )
   509	
   510	        # A first-level git submodule with a real file, cited relative to
   511	        # the submodule's own root rather than the project root.
   512	        (exempt_root / ".gitmodules").write_text(
   513	            '[submodule "vendorlib"]\n\tpath = vendorlib\n\turl = https://example.invalid/vendorlib.git\n',
   514	            encoding="utf-8",
   515	        )
   516	        (exempt_root / "vendorlib" / "pkg").mkdir(parents=True)
   517	        (exempt_root / "vendorlib" / "pkg" / "real_file.py").write_text("# real\n", encoding="utf-8")
   518	
   519	        (round_dir2 / "reviews" / "exemptions.md").write_text(
   520	            "Regex/glob spans must not be treated as path citations:\n"
   521	            "- `^_?\\s*(no|none)\\b.*declared.*_?$`\n"
   522	            "- `__pycache__/*.pyc`\n"
   523	            "\n"
   524	            "Bare-domain URLs must not be treated as path citations:\n"
   525	            "- `docs.python.org/3/library/os.html`\n"
   526	            "- `github.com/org/repo/blob/main/src/foo.py`\n"
   527	            "\n"
   528	            "Submodule-relative citation, resolves against the vendorlib submodule root:\n"
   529	            "- `pkg/real_file.py`\n"
   530	            "\n"
   531	            "Submodule-relative citation to a file that genuinely does not exist "
   532	            "(submodule bases must not blanket-exempt everything):\n"
   533	            "- `pkg/does_not_exist_in_submodule.py`\n"
   534	            "\n"
   535	            "<!-- verify:ignore -->\n"
   536	            "Explicitly ignored line citing `totally/made/up/ignored_prev_line.py`\n"
   537	            "Explicitly ignored same-line citation `totally/made/up/ignored_same_line.py` <!-- verify:ignore -->\n"
