   632	def main() -> int:
   633	    parser = argparse.ArgumentParser(
   634	        description="Report machine-readable Harnessloop setup completeness."
   635	    )
   636	    parser.add_argument("--project", "-p", default=".", help="Target project directory.")
   637	    parser.add_argument("--json", action="store_true", help="Print machine-readable JSON output.")
   638	    args = parser.parse_args()
   639	
   640	    project = Path(args.project)
   641	    if not project.exists() or not project.is_dir():
   642	        print(f"error: project path does not exist or is not a directory: {project}", file=sys.stderr)
   643	        return 2
   644	
   645	    if not REFERENCES_DIR.exists():
   646	        print(f"error: references directory not found: {REFERENCES_DIR}", file=sys.stderr)
   647	        return 2
   648	
   649	    project = project.resolve()
   650	
   651	    try:
   652	        report = build_report(project)
