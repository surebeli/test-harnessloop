   210	### 2.6 respondApproval
   211	
   212	```ts
   213	type ApprovalDecision =
   214	  | { outcome: 'allow_once'; updatedInput?: unknown }
   215	  | { outcome: 'allow_always'; scope?: string; updatedInput?: unknown }
   216	  | { outcome: 'deny'; reason?: string };
   217	// v2 新增 updatedInput 字段（消解 F-05）：v1 §6.1 的文字要求"allow 时可携带改写后的 input"，
   218	// 但 ApprovalDecision 类型本身没有承载这个字段的位置，导致 UI 批准的 payload 与最终执行参数
   219	// 无法建立可验证的同一性。v2 在 allow_once/allow_always 两个 outcome 上都补上可选的 updatedInput。
   220	
   221	function respondApproval(
   222	  session: SessionHandle,
   223	  reqId: string,
   224	  decision: ApprovalDecision
   225	): Promise<void>;
   226	// reqId 对应某条 approval_request KernelEvent 的 reqId（openclaw 场景下 reqId = 内核 approval id，
   227	// T-005 A1 确认 resolve 以 approval id 为主键，不是 toolCallId）。
   228	// exactly-once 与 pending 状态机见 §6.2；命中未知/已终态的 reqId 时 reject（approval_not_pending）。
   229	```
