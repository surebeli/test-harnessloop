143:### 2.7 capabilities
146:function capabilities(): Promise<CapabilityDescriptor>;
154:`subscribe()` 产出的事件是以下 8 类的判别联合（discriminated union），是 P3 消息 schema 的种子：
168:  seq: number;         // 单调递增序号，同一 session 内唯一；断线重放语义见第 9 节开放问题
170:  runId?: string;       // 归属的 send() 产生的 run；session 级事件（如 session_end）可省略
171:  ts: string;           // ISO 8601，来自内核侧时间戳，非 Transport 转发时间
184:  visibility: 'summary' | 'raw';  // 内核暴露的是摘要还是原始思维，见 capabilities().thinkingVisibility
188:  type: 'tool_call';
196:  type: 'tool_result';
204:  type: 'approval_request';
206:  kind: 'exec' | 'tool' | 'mcp' | 'sandbox' | 'file_write';    // 可扩展枚举，见第 6.1 节
208:  proposedDecision?: 'allow_once' | 'allow_always' | 'deny';   // 内核给出的建议（如有）
209:  timeoutMs?: number;                                          // 超时后行为未跨内核统一，见第 9 节
222:  runId: string;
224:  usage?: { inputTokens?: number; outputTokens?: number };  // 尽力字段，非计费权威来源，见第 7 节
245:  approvalGranularity: 'per-tool' | 'per-command' | 'batch';
246:  approvalKinds: Array<'exec' | 'tool' | 'mcp' | 'sandbox' | 'file_write'>;
248:  interruptModes: Array<'steer' | 'cancel'>;   // 至少含 'cancel'；子集声明见第 6.2 节
254:  sandboxLevels?: Array<'read-only' | 'workspace-write' | 'full-access'>;
256:  usageReporting: 'none' | 'best-effort' | 'authoritative';
257:  // 计费以 newapi 为权威（见第 7 节），目前四个内核都不应声明 'authoritative'
