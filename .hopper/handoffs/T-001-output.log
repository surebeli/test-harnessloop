   350	
   351	def render_leaf_value(line: str, label: str, value: str) -> str:
   352	    """Return `line` with its captured value replaced by `value`, keeping
   353	    any leading markdown decoration (list dash, bold markers, indentation)
   354	    intact. Paired with `locate_field_line` for fixture construction."""
   355	    m = _label_pattern(label).match(line)
   356	    if not m:
   357	        raise ValueError(f"label {label!r} does not match line {line!r}")
   358	    return line[: m.start(1)] + value
   359	
   360	
   361	def render_sentinel_line(heading: str) -> str:
   362	    """Build the canonical S1-tightened 'none declared' sentinel line for a
   363	    table slot under `## heading` (section 3's wizard wording, section 4.3's
   364	    matching regex): the category name is the heading's own lowercase
   365	    form."""
   366	    return f"_No {heading.lower()} declared for this project (confirmed via setup wizard)._"
   367	
   368	
   369	def locate_table_bounds(text: str, heading: str) -> Optional[Tuple[int, int]]:
   370	    """Return (separator_line_index, slice_end_index) for the table under
   371	    `## heading`, or None if the heading/separator cannot be found. Exposed
   372	    for the same fixture-construction reuse reason as `locate_field_line`."""
   373	    lines = text.splitlines()
   374	    hs = _find_heading_slice(lines, heading)
   375	    if hs is None:
   376	        return None
   377	    start, end = hs
   378	    for i in range(start, end):
   379	        if _is_separator_row(lines[i]):
   380	            return i, end
   381	    return None
   382	
   383	
   384	def _is_separator_row(line: str) -> bool:
   385	    stripped = line.strip()
   386	    if not stripped or "-" not in stripped:
   387	        return False
   388	    return bool(re.match(r"^[|:\-\s]+$", stripped))
   389	
   390	
   391	def _resolve_leaf(
   392	    text: str, heading: Optional[str], container: Optional[str], label: str, other_containers: List[str]
   393	) -> Optional[str]:
   394	    lines = text.splitlines()
   395	    if heading:
   396	        hs = _find_heading_slice(lines, heading)
   397	        if hs is None:
   398	            return None
   399	        start, end = hs
   400	    else:
   401	        start, end = 0, len(lines)
   402	
   403	    if container:
   404	        cs = _find_container_slice(lines, start, end, container, other_containers)
   405	        if cs is None:
   406	            return None
   407	        start, end = cs
   408	
   409	    label_re = _label_pattern(label)
   410	    for i in range(start, end):
   411	        m = label_re.match(lines[i])
   412	        if m:
   413	            return _clean_value(m.group(1))
   414	    return None
   415	
   416	
   417	def _resolve_table(text: str, heading: str) -> Tuple[bool, bool]:
   418	    """Return (has_data_rows, has_sentinel) for the table under `## heading`."""
   419	    lines = text.splitlines()
   420	    hs = _find_heading_slice(lines, heading)
   421	    if hs is None:
   422	        return False, False
   423	    start, end = hs
   424	
   425	    sep_idx = None
   426	    for i in range(start, end):
   427	        if _is_separator_row(lines[i]):
   428	            sep_idx = i
   429	            break
   430	
   431	    has_rows = False
   432	    if sep_idx is not None:
   433	        for j in range(sep_idx + 1, end):
   434	            # A real table row starts with `|`; a stray prose line (e.g. "not
   435	            # sure yet...") left in an otherwise-empty table section must not
   436	            # count as "answered" (M-B fix: the previous `lines[j].strip()`
   437	            # truthiness check treated any non-blank line as a data row,
   438	            # bypassing the S1 sentinel anchor -- prose neither matches the
   439	            # sentinel regex nor is a genuine row, so it must not satisfy
   440	            # either path to "filled").
   441	            if lines[j].strip().startswith("|"):
   442	                has_rows = True
   443	                break
   444	
   445	    has_sentinel = any(_SENTINEL_RE.match(lines[i]) for i in range(start, end))
   446	    return has_rows, has_sentinel
   447	
   448	
   449	def _path_string(heading: Optional[str], container: Optional[str], label: str) -> str:
   450	    parts = [p for p in (heading, container, label) if p]
   451	    return " > ".join(parts)
   452	
   453	
   454	def _template_name_for(rel: str) -> str:
   455	    return init_project.BASE_FILES[rel]
   456	
   457	
   458	def _file_report(project: Path, rel: str) -> dict:
   459	    spec = MANIFEST[rel]
   460	    total = len(spec["fields"]) + len(spec["tables"])
   461	    path = project / rel
   462	
   463	    if not path.exists():
   464	        missing_sections = [_path_string(h, c, l) for h, c, l in spec["fields"]] + list(
   465	            spec["tables"]
   466	        )
   467	        return {
   468	            "state": "missing",
   469	            "missing_sections": missing_sections,
   470	            "fields_filled": 0,
   471	            "fields_total": total,
   472	            "field_todo": 0,
   473	        }
   474	
   475	    text = path.read_text(encoding="utf-8")
   476	    template_text = init_project.read_template(_template_name_for(rel))
   477	    containers_by_heading = _containers_by_heading(spec["fields"])
   478	
   479	    missing_sections: List[str] = []
   480	    filled_count = 0
   481	    field_todo = 0
   482	
   483	    for heading, container, label in spec["fields"]:
   484	        other = containers_by_heading.get(heading, []) if heading else []
   485	        resolved = _resolve_leaf(text, heading, container, label, other)
   486	        template_value = _resolve_leaf(template_text, heading, container, label, other)
   487	        if template_value is None:
   488	            template_value = ""
   489	
   490	        if resolved is None:
   491	            filled = False
   492	        else:
   493	            filled = not (resolved == "" or resolved == template_value)
   494	            if filled and resolved.startswith(TODO_LITERAL):
   495	                field_todo += 1
   496	
   497	        if filled:
   498	            filled_count += 1
   499	        else:
   500	            missing_sections.append(_path_string(heading, container, label))
   501	
   502	    for heading in spec["tables"]:
   503	        has_rows, has_sentinel = _resolve_table(text, heading)
   504	        if has_rows or has_sentinel:
   505	            filled_count += 1
   506	        else:
   507	            missing_sections.append(heading)
   508	
   509	    if filled_count == 0:
   510	        state = "template"
   511	    elif filled_count == total:
   512	        state = "filled"
   513	    else:
   514	        state = "partial"
   515	
   516	    return {
   517	        "state": state,
   518	        "missing_sections": missing_sections,
   519	        "fields_filled": filled_count,
   520	        "fields_total": total,
   521	        "field_todo": field_todo,
   522	    }
   523	
   524	
   525	def _count_selfcheck_todos(project: Path) -> int:
   526	    """Count `TODO (owner: user):`-formatted entries inside self-check.md's
   527	    `Action` field (see module docstring re: field_todo_count vs
   528	    selfcheck_todo_count -- these are deliberately never merged)."""
   529	    path = project / ".harnessloop/state/self-check.md"
   530	    if not path.exists():
   531	        return 0
   532	    text = path.read_text(encoding="utf-8")
   533	    lines = text.splitlines()
   534	
   535	    action_re = _label_pattern("Action")
   536	    last_checked_re = _label_pattern("Last checked")
   537	
   538	    start = None
   539	    for i, line in enumerate(lines):
   540	        if action_re.match(line):
   541	            start = i
   542	            break
   543	    if start is None:
   544	        return 0
   545	
   546	    end = len(lines)
   547	    for j in range(start + 1, len(lines)):
   548	        if last_checked_re.match(lines[j]):
   549	            end = j
   550	            break
   551	
   552	    block = "\n".join(lines[start:end])
   553	    return len(re.findall(re.escape(TODO_LITERAL) + r"\s*:", block))
   554	
   555	
   556	def build_report(project: Path) -> dict:
   557	    files_report: "dict[str, dict]" = {}
   558	    complete = True
   559	    filled_files = 0
   560	    gate_blocking = False
   561	    field_todo_total = 0
   562	
   563	    for rel in FILES_ORDER:
   564	        fr = _file_report(project, rel)
   565	        field_todo_total += fr.pop("field_todo")
   566	        files_report[rel] = fr
   567	        if fr["state"] == "filled":
   568	            filled_files += 1
   569	        else:
   570	            complete = False
   571	        if rel in GATE_BLOCKING_FILES and fr["state"] in ("template", "missing"):
   572	            gate_blocking = True
   573	
   574	    selfcheck_todo_count = _count_selfcheck_todos(project)
   575	
   576	    next_step = None
   577	    for rel in FILES_ORDER:
   578	        if files_report[rel]["state"] != "filled":
   579	            next_step = rel
   580	            break
   581	
   582	    return {
   583	        "project": str(project),
   584	        "files": files_report,
   585	        "complete": complete,
   586	        "filled": filled_files,
   587	        "total": len(FILES_ORDER),
   588	        "gate_blocking": gate_blocking,
   589	        "field_todo_count": field_todo_total,
   590	        "selfcheck_todo_count": selfcheck_todo_count,
   591	        "next_step": next_step,
   592	    }
   593	
   594	
   595	def _print_human(report: dict) -> None:
   596	    print(f"Harnessloop setup check: {report['project']}")
   597	    for rel in FILES_ORDER:
   598	        fr = report["files"][rel]
   599	        display = rel.removeprefix(".harnessloop/")
   600	        line = f"  {display}: {fr['state']} ({fr['fields_filled']}/{fr['fields_total']})"
   601	        if fr["missing_sections"]:
   602	            line += " — missing: " + ", ".join(fr["missing_sections"])
   603	        print(line)
   604	
   605	    print(f"Setup completeness: {report['filled']}/{report['total']} files fully filled.")
   606	
   607	    if report["gate_blocking"]:
   608	        blocking_file = None
   609	        for rel in FILES_ORDER:
   610	            if rel in GATE_BLOCKING_FILES and report["files"][rel]["state"] in ("template", "missing"):
   611	                blocking_file = rel
   612	                break
   613	        display = blocking_file.removeprefix(".harnessloop/") if blocking_file else "unknown"
   614	        print(f"Setup gate: BLOCKING — {display} is still {report['files'][blocking_file]['state']}.")
   615	    elif not report["complete"]:
   616	        print(f"Setup gate: WARNING — {report['total'] - report['filled']} file(s) incomplete (non-blocking).")
   617	    else:
   618	        print("Setup gate: COMPLETE.")
   619	
   620	    print(
   621	        f"TODO count: field={report['field_todo_count']}, "
   622	        f"self-check={report['selfcheck_todo_count']}"
   623	    )
   624	
   625	    if report["next_step"]:
   626	        display = report["next_step"].removeprefix(".harnessloop/")
   627	        print(f"Next setup step: {display} (run $harnessloop-setup)")
   628	    else:
   629	        print("Next setup step: none (setup complete)")
   630	
