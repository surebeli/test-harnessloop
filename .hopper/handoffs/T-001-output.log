   134	def _fill_setup_project(root: Path) -> None:
   135	    """Programmatically fill every leaf field / table slot check_setup.py's
   136	    manifest defines, deriving edit locations directly from
   137	    check_setup.MANIFEST / locate_field_line / locate_table_bounds so this
   138	    fixture can never drift out of sync with the detector it exercises
   139	    (design-v2 section 7.2 bullet 2: deliberately not reusing
   140	    examples/mock-project, whose structure is already known to lag the
   141	    current templates).
   142	    """
   143	    init_project.initialize(root, None, False, False)
   144	    for rel in check_setup.FILES_ORDER:
   145	        path = root / rel
   146	        spec = check_setup.MANIFEST[rel]
   147	        text = path.read_text(encoding="utf-8")
   148	
   149	        if spec["fields"]:
   150	            lines = text.splitlines()
   151	            for heading, container, label in spec["fields"]:
   152	                idx = check_setup.locate_field_line(text, rel, heading, container, label)
   153	                if idx is None:
   154	                    raise AssertionError(f"fixture: cannot locate field {label!r} in {rel}")
   155	                lines[idx] = check_setup.render_leaf_value(lines[idx], label, "value")
   156	            text = "\n".join(lines) + "\n"
   157	
   158	        for heading in spec["tables"]:
   159	            bounds = check_setup.locate_table_bounds(text, heading)
   160	            if bounds is None:
   161	                raise AssertionError(f"fixture: cannot locate table {heading!r} in {rel}")
   162	            sep_idx, _slice_end = bounds
   163	            lines = text.splitlines()
   164	            lines.insert(sep_idx + 1, check_setup.render_sentinel_line(heading))
   165	            text = "\n".join(lines) + "\n"
   166	
   167	        path.write_text(text, encoding="utf-8")
   168	
   169	
   170	def _run_check_setup(project: Path) -> subprocess.CompletedProcess:
   171	    return run_python(LOOP_SCRIPTS / "check_setup.py", "--project", str(project), "--json")
   172	
   173	
   174	def _run_check_setup_json(project: Path, expected_exit: int, label: str) -> dict:
   175	    result = _run_check_setup(project)
   176	    check(result.returncode == expected_exit, f"{label}: check_setup.py exits {expected_exit}")
   177	    if result.returncode != expected_exit or not result.stdout.strip():
   178	        print(result.stdout + result.stderr)
   179	        return {}
   180	    try:
   181	        return json.loads(result.stdout)
   182	    except json.JSONDecodeError:
   183	        print(result.stdout + result.stderr)
   184	        return {}
